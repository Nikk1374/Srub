<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>СрубМастер — Деревянное строительство</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}

:root{
  --cream:#f7f3ec;
  --cream2:#f0e9dc;
  --cream3:#e6dccb;
  --dark:#1c1a16;
  --dark2:#2a2720;
  --dark3:#3d3a32;
  --text:#3a3628;
  --muted:#7c7668;
  --muted2:#a89f92;
  --green:#4a7c35;
  --green2:#3a6228;
  --green-light:#edf4e8;
  --amber:#9a6b1a;
  --amber-light:#f8f0e0;
  --border:rgba(60,54,40,0.1);
  --border2:rgba(60,54,40,0.2);
  --serif:'Cormorant Garamond',serif;
  --sans:'Jost',sans-serif;
}

body{
  background:var(--cream);
  color:var(--text);
  font-family:var(--sans);
  font-weight:400;
  line-height:1.7;
  overflow-x:hidden;
}

/* ─── NAV ─── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  height:80px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 60px;
  transition:background 0.4s,box-shadow 0.4s;
}
nav.solid{
  background:rgba(247,243,236,0.97);
  backdrop-filter:blur(16px);
  box-shadow:0 1px 0 var(--border);
}
.logo{
  display:flex;align-items:center;gap:14px;
  text-decoration:none;
}
.logo-mark{
  width:42px;height:42px;
  background:var(--dark);
  display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
}
.logo-mark svg{width:24px;height:24px}
.logo-name{
  font-family:var(--serif);
  font-size:22px;font-weight:600;
  color:var(--dark);letter-spacing:0.02em;
}
.logo-name span{color:var(--green)}

.nav-menu{display:flex;align-items:center;gap:40px;list-style:none}
.nav-menu a{
  font-size:13px;font-weight:500;
  letter-spacing:0.08em;text-transform:uppercase;
  color:var(--muted);text-decoration:none;
  transition:color 0.2s;
}
.nav-menu a:hover{color:var(--dark)}
.nav-phone{
  font-family:var(--serif);
  font-size:18px;font-weight:600;
  color:var(--dark);text-decoration:none;
  transition:color 0.2s;
}
.nav-phone:hover{color:var(--green)}

/* ─── HERO ─── */
.hero{
  min-height:100vh;
  display:grid;
  grid-template-columns:1fr 1fr;
  position:relative;
  overflow:hidden;
}

.hero-left{
  background:var(--dark);
  display:flex;flex-direction:column;
  justify-content:flex-end;
  padding:120px 70px 80px;
  position:relative;
  overflow:hidden;
}

.hero-left-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse at 20% 80%, rgba(74,124,53,0.15) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 20%, rgba(154,107,26,0.1) 0%, transparent 60%);
}

.hero-lines{
  position:absolute;top:0;right:0;bottom:0;
  width:1px;background:rgba(255,255,255,0.08);
}
.hero-lines::before{
  content:'';position:absolute;
  top:0;left:-40px;bottom:0;width:1px;
  background:rgba(255,255,255,0.04);
}

.hero-eyebrow{
  display:flex;align-items:center;gap:12px;
  font-size:11px;font-weight:500;
  letter-spacing:0.2em;text-transform:uppercase;
  color:var(--green);
  margin-bottom:28px;
  position:relative;z-index:1;
  opacity:0;animation:fadeUp 0.8s 0.3s forwards;
}
.hero-eyebrow-line{width:32px;height:1px;background:var(--green)}

.hero-h1{
  font-family:var(--serif);
  font-size:clamp(52px,6vw,84px);
  font-weight:300;
  line-height:1.0;
  color:#fff;
  letter-spacing:-0.01em;
  margin-bottom:28px;
  position:relative;z-index:1;
  opacity:0;animation:fadeUp 0.9s 0.5s forwards;
}
.hero-h1 em{
  font-style:italic;
  color:rgba(255,255,255,0.45);
  display:block;
}
.hero-h1 strong{
  font-weight:700;
  color:#fff;
}

.hero-desc{
  font-size:15px;font-weight:300;
  color:rgba(255,255,255,0.5);
  max-width:380px;line-height:1.8;
  margin-bottom:44px;
  position:relative;z-index:1;
  opacity:0;animation:fadeUp 0.9s 0.7s forwards;
}

.hero-actions{
  display:flex;align-items:center;gap:20px;
  position:relative;z-index:1;
  opacity:0;animation:fadeUp 0.9s 0.9s forwards;
}

.btn-main{
  background:var(--green);color:#fff;
  padding:16px 36px;
  font-family:var(--sans);
  font-size:12px;font-weight:600;
  letter-spacing:0.12em;text-transform:uppercase;
  text-decoration:none;border:none;cursor:pointer;
  display:inline-flex;align-items:center;gap:10px;
  transition:background 0.25s,transform 0.15s;
  position:relative;overflow:hidden;
}
.btn-main::after{
  content:'';
  position:absolute;inset:0;
  background:rgba(255,255,255,0.1);
  transform:translateX(-100%);
  transition:transform 0.4s;
}
.btn-main:hover{background:var(--green2);transform:translateY(-2px)}
.btn-main:hover::after{transform:translateX(0)}

.btn-outline{
  font-size:12px;font-weight:500;
  letter-spacing:0.1em;text-transform:uppercase;
  color:rgba(255,255,255,0.5);
  text-decoration:none;
  display:inline-flex;align-items:center;gap:8px;
  transition:color 0.2s;
  border:none;background:none;cursor:pointer;padding:0;
}
.btn-outline:hover{color:#fff}
.btn-outline-arrow{
  width:36px;height:36px;
  border:1px solid rgba(255,255,255,0.15);
  display:flex;align-items:center;justify-content:center;
  transition:border-color 0.2s,background 0.2s;
}
.btn-outline:hover .btn-outline-arrow{border-color:rgba(255,255,255,0.4);background:rgba(255,255,255,0.05)}

.hero-stats{
  display:flex;gap:0;
  margin-top:60px;
  padding-top:40px;
  border-top:1px solid rgba(255,255,255,0.08);
  position:relative;z-index:1;
  opacity:0;animation:fadeUp 0.9s 1.1s forwards;
}
.hero-stat{
  flex:1;
  padding-right:28px;
  border-right:1px solid rgba(255,255,255,0.08);
  margin-right:28px;
}
.hero-stat:last-child{border-right:none;margin-right:0}
.hero-stat-n{
  font-family:var(--serif);
  font-size:38px;font-weight:600;
  color:#fff;line-height:1;
  margin-bottom:4px;
}
.hero-stat-l{font-size:11px;color:rgba(255,255,255,0.35);letter-spacing:0.05em}

.hero-right{
  position:relative;
  overflow:hidden;
}

.hero-img{
  position:absolute;inset:0;
  background:linear-gradient(160deg, #5a4020 0%, #3a2810 30%, #1e1408 100%);
  display:flex;align-items:center;justify-content:center;
}

.hero-img-art{
  width:100%;height:100%;
  position:relative;
  overflow:hidden;
}

/* Decorative wood grain art */
.wood-art{
  position:absolute;inset:0;
  background:
    repeating-linear-gradient(
      8deg,
      transparent,
      transparent 18px,
      rgba(200,160,80,0.04) 18px,
      rgba(200,160,80,0.04) 19px
    ),
    repeating-linear-gradient(
      -5deg,
      transparent,
      transparent 30px,
      rgba(160,100,40,0.03) 30px,
      rgba(160,100,40,0.03) 31px
    );
}

.hero-img-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to right, rgba(28,26,22,0.3) 0%, transparent 40%),
             linear-gradient(to top, rgba(28,26,22,0.6) 0%, transparent 50%);
}

.hero-badge-float{
  position:absolute;
  bottom:48px;left:40px;
  background:rgba(247,243,236,0.96);
  backdrop-filter:blur(8px);
  padding:20px 24px;
  border-left:3px solid var(--green);
  animation:fadeUp 0.9s 1.3s both;
}
.hbf-top{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px}
.hbf-val{font-family:var(--serif);font-size:22px;font-weight:600;color:var(--dark)}
.hbf-sub{font-size:12px;color:var(--muted);margin-top:2px}

/* Decorative house silhouette */
.house-silhouette{
  position:absolute;
  bottom:0;left:0;right:0;
  height:55%;
  opacity:0.12;
}

@keyframes fadeUp{
  from{opacity:0;transform:translateY(28px)}
  to{opacity:1;transform:translateY(0)}
}

/* ─── MARQUEE ─── */
.marquee-wrap{
  background:var(--dark2);
  padding:20px 0;
  overflow:hidden;
  border-top:1px solid rgba(255,255,255,0.04);
}
.marquee-track{
  display:flex;
  animation:marquee 20s linear infinite;
  white-space:nowrap;
}
.marquee-item{
  display:flex;align-items:center;gap:16px;
  padding:0 40px;
  font-size:12px;font-weight:500;
  letter-spacing:0.15em;text-transform:uppercase;
  color:rgba(255,255,255,0.25);
  flex-shrink:0;
}
.marquee-dot{
  width:4px;height:4px;border-radius:50%;
  background:var(--green);opacity:0.6;
}
@keyframes marquee{
  from{transform:translateX(0)}
  to{transform:translateX(-50%)}
}

/* ─── SECTION BASE ─── */
.section{padding:120px 0}
.container{max-width:1200px;margin:0 auto;padding:0 60px}

.eyebrow{
  display:flex;align-items:center;gap:12px;
  font-size:11px;font-weight:600;
  letter-spacing:0.18em;text-transform:uppercase;
  color:var(--green);margin-bottom:16px;
}
.eyebrow-line{width:28px;height:1px;background:var(--green)}

h2.display{
  font-family:var(--serif);
  font-size:clamp(36px,4vw,58px);
  font-weight:300;
  line-height:1.15;
  color:var(--dark);
  letter-spacing:-0.01em;
}
h2.display strong{font-weight:700}
h2.display em{font-style:italic;color:var(--muted)}

/* ─── SERVICES ─── */
.services{background:var(--cream)}

.services-intro{
  display:grid;grid-template-columns:1fr 1fr;
  gap:80px;align-items:end;
  margin-bottom:72px;
}
.services-intro-text p{
  font-size:16px;font-weight:300;
  color:var(--muted);line-height:1.9;
  margin-top:20px;
}

.services-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:2px;
  background:var(--border);
}

.svc{
  background:var(--cream);
  padding:48px 36px;
  position:relative;
  overflow:hidden;
  transition:background 0.3s;
  cursor:default;
}
.svc::after{
  content:'';
  position:absolute;bottom:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--green),var(--amber));
  transform:scaleX(0);transform-origin:left;
  transition:transform 0.4s cubic-bezier(0.4,0,0.2,1);
}
.svc:hover{background:#fff}
.svc:hover::after{transform:scaleX(1)}

.svc-num{
  font-family:var(--serif);
  font-size:56px;font-weight:700;
  color:var(--cream3);
  line-height:1;margin-bottom:24px;
  transition:color 0.3s;
}
.svc:hover .svc-num{color:var(--cream2)}

.svc-icon{
  width:52px;height:52px;margin-bottom:20px;
}
.svc-icon svg{width:100%;height:100%}

.svc-title{
  font-family:var(--serif);
  font-size:26px;font-weight:600;
  color:var(--dark);margin-bottom:12px;
  line-height:1.2;
}
.svc-desc{
  font-size:14px;font-weight:300;
  color:var(--muted);line-height:1.85;
  margin-bottom:24px;
}
.svc-list{
  list-style:none;
  display:flex;flex-direction:column;gap:8px;
}
.svc-list li{
  font-size:13px;color:var(--muted);
  display:flex;align-items:flex-start;gap:10px;
  line-height:1.5;
}
.svc-list li::before{
  content:'';
  width:16px;height:1px;background:var(--green);
  flex-shrink:0;margin-top:8px;
}

/* ─── ABOUT ─── */
.about{
  background:var(--dark);
  position:relative;overflow:hidden;
}
.about-inner{
  display:grid;grid-template-columns:1fr 1fr;
  gap:100px;align-items:center;
}
.about .eyebrow{color:rgba(255,255,255,0.4)}
.about .eyebrow-line{background:rgba(255,255,255,0.2)}
.about h2.display{color:#fff}
.about h2.display em{color:rgba(255,255,255,0.3)}

.about-text{
  font-size:16px;font-weight:300;
  color:rgba(255,255,255,0.45);
  line-height:1.9;margin-top:24px;margin-bottom:40px;
}

.about-vals{
  display:flex;flex-direction:column;gap:0;
  border:1px solid rgba(255,255,255,0.07);
}
.about-val{
  display:flex;align-items:flex-start;gap:24px;
  padding:28px 32px;
  border-bottom:1px solid rgba(255,255,255,0.06);
  transition:background 0.25s;
}
.about-val:last-child{border-bottom:none}
.about-val:hover{background:rgba(255,255,255,0.03)}
.about-val-n{
  font-family:var(--serif);
  font-size:32px;font-weight:700;
  color:var(--green);
  min-width:70px;line-height:1;
  padding-top:4px;
}
.about-val-title{
  font-family:var(--serif);
  font-size:17px;font-weight:600;
  color:#fff;margin-bottom:4px;
}
.about-val-desc{font-size:13px;color:rgba(255,255,255,0.4);line-height:1.7}

.about-bg-text{
  position:absolute;
  right:-40px;top:50%;transform:translateY(-50%);
  font-family:var(--serif);
  font-size:240px;font-weight:700;
  color:rgba(255,255,255,0.015);
  white-space:nowrap;pointer-events:none;
  user-select:none;letter-spacing:-0.05em;
}

/* ─── PROCESS ─── */
.process{background:var(--cream2)}

.process-steps{
  display:grid;grid-template-columns:repeat(5,1fr);
  gap:0;margin-top:72px;
  position:relative;
}
.process-line{
  position:absolute;
  top:28px;left:10%;right:10%;
  height:1px;background:var(--border2);
  z-index:0;
}
.step{
  position:relative;z-index:1;
  display:flex;flex-direction:column;align-items:center;
  text-align:center;padding:0 12px;
}
.step-circle{
  width:56px;height:56px;
  border:1px solid var(--border2);
  background:var(--cream2);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:24px;
  transition:background 0.3s,border-color 0.3s;
  position:relative;
}
.step-circle::after{
  content:'';
  position:absolute;inset:6px;
  background:var(--green);
  opacity:0;
  transition:opacity 0.3s;
}
.step:hover .step-circle{border-color:var(--green);background:#fff}
.step:hover .step-circle::after{opacity:1}
.step-n{
  font-family:var(--serif);
  font-size:18px;font-weight:700;
  color:var(--muted2);
  position:relative;z-index:1;
  transition:color 0.3s;
}
.step:hover .step-n{color:#fff}
.step-title{
  font-family:var(--serif);
  font-size:16px;font-weight:600;
  color:var(--dark);margin-bottom:6px;
}
.step-desc{font-size:12px;color:var(--muted);line-height:1.7}

/* ─── GEO ─── */
.geo{background:var(--cream)}

.geo-inner{
  display:grid;grid-template-columns:5fr 7fr;
  gap:80px;align-items:start;
  margin-top:72px;
}

.geo-left p{
  font-size:15px;font-weight:300;
  color:var(--muted);line-height:1.9;
  margin-top:16px;margin-bottom:32px;
}

.geo-callout{
  background:var(--dark);
  padding:32px;
  display:flex;flex-direction:column;gap:4px;
  margin-bottom:8px;
}
.geo-callout-n{
  font-family:var(--serif);
  font-size:48px;font-weight:700;
  color:#fff;line-height:1;
}
.geo-callout-n span{color:var(--green)}
.geo-callout-l{font-size:13px;color:rgba(255,255,255,0.4);margin-top:6px}

.geo-other{
  background:var(--cream3);
  padding:20px 24px;
  font-size:13px;color:var(--muted);
  border-left:3px solid var(--amber);
  line-height:1.7;
}
.geo-other strong{color:var(--dark);font-weight:600}

.regions{
  display:grid;grid-template-columns:1fr 1fr;
  gap:2px;background:var(--border);
  border:1px solid var(--border2);
}
.region{
  background:var(--cream);
  padding:20px 24px;
  display:flex;align-items:center;gap:14px;
  transition:background 0.2s;
}
.region:hover{background:#fff}
.r-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.r-body{}
.r-name{font-size:14px;font-weight:500;color:var(--dark)}
.r-tag{font-size:11px;color:var(--muted);margin-top:1px}
.region.primary .r-dot{background:var(--green);box-shadow:0 0 0 3px rgba(74,124,53,0.15)}
.region.primary .r-name{font-weight:600}
.region.secondary .r-dot{background:var(--amber)}

/* ─── CTA ─── */
.cta-section{
  background:var(--green);
  padding:100px 0;
  position:relative;overflow:hidden;
}
.cta-section::before{
  content:'';
  position:absolute;inset:0;
  background:repeating-linear-gradient(
    45deg,
    transparent,transparent 40px,
    rgba(255,255,255,0.02) 40px,rgba(255,255,255,0.02) 41px
  );
}
.cta-inner{
  position:relative;z-index:1;
  max-width:680px;margin:0 auto;text-align:center;
}
.cta-inner h2{
  font-family:var(--serif);
  font-size:clamp(36px,5vw,62px);
  font-weight:300;
  color:#fff;line-height:1.15;
  margin-bottom:16px;
}
.cta-inner h2 strong{font-weight:700}
.cta-inner p{
  font-size:16px;font-weight:300;
  color:rgba(255,255,255,0.65);
  margin-bottom:48px;line-height:1.8;
}
.cta-phone-big{
  font-family:var(--serif);
  font-size:clamp(32px,5vw,54px);
  font-weight:600;
  color:#fff;
  text-decoration:none;
  display:block;
  margin-bottom:16px;
  transition:opacity 0.2s;
}
.cta-phone-big:hover{opacity:0.8}
.cta-note{font-size:13px;color:rgba(255,255,255,0.45)}

/* ─── CONTACTS ─── */
.contacts{background:var(--dark2);padding:80px 0}

.contacts-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:2px;background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.04);
  margin-top:56px;
}
.contact-block{
  padding:40px 44px;
  transition:background 0.25s;
}
.contact-block:hover{background:rgba(255,255,255,0.03)}
.cb-label{
  font-size:10px;font-weight:600;
  letter-spacing:0.18em;text-transform:uppercase;
  color:rgba(255,255,255,0.25);margin-bottom:12px;
}
.cb-val{
  font-family:var(--serif);
  font-size:24px;font-weight:600;
  color:#fff;text-decoration:none;
  display:block;margin-bottom:6px;
  transition:color 0.2s;
}
.cb-val:hover{color:var(--green)}
.cb-sub{font-size:13px;color:rgba(255,255,255,0.3)}

/* ─── FOOTER ─── */
footer{
  background:var(--dark);
  padding:32px 60px;
  display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid rgba(255,255,255,0.04);
  flex-wrap:wrap;gap:16px;
}
.footer-logo{
  font-family:var(--serif);
  font-size:18px;font-weight:600;
  color:rgba(255,255,255,0.6);
}
.footer-logo span{color:var(--green)}
.footer-copy{font-size:12px;color:rgba(255,255,255,0.2)}

/* ─── REVEAL ─── */
.reveal{opacity:0;transform:translateY(32px);transition:opacity 0.8s cubic-bezier(0.4,0,0.2,1),transform 0.8s cubic-bezier(0.4,0,0.2,1)}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-delay-1{transition-delay:0.1s}
.reveal-delay-2{transition-delay:0.2s}
.reveal-delay-3{transition-delay:0.3s}

/* ─── MOBILE ─── */
@media(max-width:960px){
  nav{padding:0 24px}
  .nav-menu{display:none}
  .hero{grid-template-columns:1fr;min-height:auto}
  .hero-left{padding:120px 28px 60px}
  .hero-right{height:300px}
  .about-inner,.services-intro,.geo-inner{grid-template-columns:1fr;gap:40px}
  .process-steps{grid-template-columns:1fr 1fr;gap:32px}
  .process-line{display:none}
